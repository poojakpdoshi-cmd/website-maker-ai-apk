# Mobile public variables
VITE_API_BASE_URL=https://YOUR-WORKER.workers.dev
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Cloudflare Worker secrets (set with wrangler secret put)
# Owner login defaults to username Poojak@King and the requested password hash.
# The optional values below let you rotate the credentials later without editing code.
ADMIN_USERNAME=Poojak@King
ADMIN_PASSWORD_SALT=
ADMIN_PASSWORD_HASH=
ADMIN_PASSWORD_ITERATIONS=60000
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
PUBLIC_API_BASE_URL=https://YOUR-WORKER.workers.dev

# Optional AI provider. Without these, the built-in zero-cost planning brain still works.
GEMINI_API_KEY=
GEMINI_MODEL=

# GitHub OAuth App
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://YOUR-WORKER.workers.dev/integrations/github/callback

# Vercel Integration
VERCEL_CLIENT_ID=
VERCEL_CLIENT_SECRET=
VERCEL_REDIRECT_URI=https://YOUR-WORKER.workers.dev/integrations/vercel/callback
VERCEL_INTEGRATION_SLUG=

# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# Mobile owner entry
VITE_ADMIN_EMAIL=poojakpdoshi@gmail.com
VITE_ADMIN_URL=http://127.0.0.1:5174/
