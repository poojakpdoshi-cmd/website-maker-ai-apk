/* Claude-inspired WebForge chat workspace */

.chat-studio {
  width: 100%;
  min-height: 640px;
  display: flex;
  flex-direction: column;
  gap: 18px;
  padding: 18px;
  border: 1px solid #ddd8cf;
  border-radius: 26px;
  background: #f7f5f1;
  box-shadow: 0 22px 55px rgba(49, 45, 39, .08);
}

.chat-studio-topbar {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14px;
  padding: 4px 4px 16px;
  border-bottom: 1px solid #e2ddd4;
}

.chat-studio-topbar h2 {
  margin: 0;
  font-size: clamp(25px, 6vw, 38px);
  color: #25221f !important;
}

.chat-model-badge {
  flex: 0 0 auto;
  padding: 8px 11px;
  border: 1px solid #d8d1c6;
  border-radius: 999px;
  background: #fffdf9;
  color: #6f665d;
  font-size: 11px;
  font-weight: 800;
}

.chat-thread {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 22px;
  min-height: 280px;
  padding: 14px 4px;
}

.chat-message {
  display: grid;
  grid-template-columns: 38px minmax(0, 1fr);
  gap: 12px;
  align-items: flex-start;
}

.chat-message.user {
  width: min(88%, 680px);
  align-self: flex-end;
  padding: 14px;
  border: 1px solid #ddd8cf;
  border-radius: 20px;
  background: #ece9e3;
}

.chat-avatar {
  width: 38px;
  height: 38px;
  display: grid;
  place-items: center;
  border: 1px solid #d7d0c5;
  border-radius: 12px;
  background: #fffdf9;
  color: #2e2a26;
  font-size: 12px;
  font-weight: 900;
}

.chat-message.user .chat-avatar {
  background: #2f2b27;
  color: #fff;
  border-color: #2f2b27;
}

.chat-message-content {
  min-width: 0;
}

.chat-message-content strong {
  display: block;
  margin-bottom: 5px;
  color: #292622 !important;
  font-size: 13px;
}

.chat-message-content p {
  margin: 0;
  color: #3f3a35;
  line-height: 1.65;
  white-space: pre-wrap;
  overflow-wrap: anywhere;
}

.chat-thinking {
  color: #81776e !important;
}

.chat-thinking::after {
  content: " ...";
  animation: chatPulse 1.1s infinite;
}

@keyframes chatPulse {
  0%, 100% { opacity: .35; }
  50% { opacity: 1; }
}

.chat-starters {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
}

.chat-starters button {
  min-height: 52px;
  text-align: left;
  border: 1px solid #ddd7cd !important;
  border-radius: 16px !important;
  background: #fffdf9 !important;
  color: #4d4640 !important;
  box-shadow: none !important;
}

.chat-starters button:hover {
  border-color: #bdb4a8 !important;
  background: #f2eee8 !important;
}

.chat-composer {
  position: sticky;
  bottom: 10px;
  z-index: 4;
  display: block;
  margin: 0;
  padding: 12px;
  border: 1px solid #d5cec3;
  border-radius: 22px;
  background: rgba(255, 253, 249, .97);
  box-shadow: 0 18px 45px rgba(55, 49, 43, .12);
  backdrop-filter: blur(18px);
}

.chat-composer textarea {
  min-height: 86px;
  padding: 8px 8px 2px !important;
  border: 0 !important;
  border-radius: 0 !important;
  background: transparent !important;
  color: #28241f !important;
  box-shadow: none !important;
  resize: none;
}

.chat-composer textarea:focus {
  border: 0 !important;
  box-shadow: none !important;
}

.chat-composer-actions {
  display: grid;
  grid-template-columns: 1fr auto auto;
  gap: 10px;
  align-items: center;
  margin-top: 10px;
}

.chat-composer-actions > span {
  color: #958b82;
  font-size: 10px;
}

.chat-attach-button,
.chat-preview-button {
  border: 1px solid #d7d0c6 !important;
  background: #fffdf9 !important;
  color: #5f574f !important;
  box-shadow: none !important;
}

.chat-send-button {
  min-width: 88px;
  border-color: #302c28 !important;
  background: #302c28 !important;
  color: #fff !important;
  box-shadow: none !important;
}

.chat-file-input {
  display: none;
}

.chat-image-preview {
  display: grid;
  grid-template-columns: 44px minmax(0, 1fr) 32px;
  gap: 9px;
  align-items: center;
  margin-bottom: 8px;
  padding: 7px;
  border: 1px solid #dfd8ce;
  border-radius: 14px;
  background: #f2eee8;
}

.chat-image-preview img {
  width: 44px;
  height: 44px;
  border-radius: 10px;
  object-fit: cover;
}

.chat-image-preview span {
  overflow: hidden;
  color: #5b534c;
  font-size: 12px;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chat-image-preview button {
  width: 30px;
  height: 30px;
  padding: 0 !important;
  border-radius: 50% !important;
  background: transparent !important;
  color: #6f665e !important;
  box-shadow: none !important;
}

.chat-preview-button {
  align-self: flex-start;
}

@media (max-width: 620px) {
  .chat-studio {
    min-height: 72vh;
    padding: 14px;
    border-radius: 22px;
  }

  .chat-studio-topbar {
    flex-direction: column;
  }

  .chat-starters {
    grid-template-columns: 1fr;
  }

  .chat-message.user {
    width: 94%;
  }

  .chat-composer-actions {
    grid-template-columns: 1fr auto;
  }

  .chat-composer-actions > span {
    display: none;
  }
}

.webforge-app-nav {
  grid-template-columns: repeat(6, minmax(0, 1fr)) !important;
}

@media (max-width: 620px) {
  .webforge-app-nav {
    grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
  }
}
